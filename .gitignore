# Zsh ephemeral files
.zsh_history
.zcompdump*
.zsh_sessions/

# macOS
.DS_Store
.CFUserTextEncoding

# Editor temp files
.swp
.swo
*~

# IDE
.idea/
.vscode/

# Python
__pycache__/
*.pyc

# Node
node_modules/
npm-debug.log

# Environment
.env
.env.local

# spotify-player (real config has client_id, only example is versioned)
spotify-player/.config/spotify-player/app.toml
spotify-player/.config/spotify-player/.cache/
spotify-player/.config/spotify-player/credentials.json

# Tool-managed auth/credentials state — must never be tracked
**/auth.json
**/credentials.json
**/.env
**/.env.local

# pi: everything under ~/.pi/agent/ is tool-managed (auth, runtime state,
# downloaded binaries). Only pi/.pi/settings.json (skills config) is tracked.
pi/.pi/agent/
