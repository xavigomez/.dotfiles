{
  "agent": {
    "dock": "left",
    "tool_permissions": {
      "tools": {
        "fetch": {
          "always_allow": [
            {
              "pattern": "^https?://www\\.storyblok\\.com"
            }
          ]
        }
      }
    },
    "default_profile": "ask",
    "default_model": {
      "provider": "zed.dev",
      "model": "claude-sonnet-4-6",
      "enable_thinking": true,
      "effort": "high"
    },
    "favorite_models": [],
    "model_parameters": []
  },
  "agent_servers": {
    "claude-acp": {
      "type": "registry"
    }
  },
  "buffer_font_size": 18.0,
  "buffer_font_weight": 400.0,
  "buffer_line_height": "comfortable",
  "collaboration_panel": {
    "dock": "right"
  },
  "git_panel": {
    "dock": "right"
  },
  "icon_theme": "Catppuccin Macchiato",
  "languages": {
    "Rust": {
      "format_on_save": "on"
    }
  },
  "lsp": {
    "rust-analyzer": {
      "initialization_options": {
        "check": {
          "command": "clippy"
        }
      }
    }
  },
  "outline_panel": {
    "dock": "right"
  },
  "project_panel": {
    "dock": "right"
  },
  "theme": "Ayu Mirage",
  "ui_font_size": 16,
  "vim_mode": true
}
